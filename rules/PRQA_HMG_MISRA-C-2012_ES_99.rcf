        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-8.1.html" active="yes" id="Rule-8.1">
          <text>Types shall be explicitly specified</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
            <category>Declarations and definitions</category>
