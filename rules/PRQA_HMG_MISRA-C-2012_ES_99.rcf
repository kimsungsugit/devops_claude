    <rule help="C:\PRQA\PRQA-Framework-2.2.0\config\rcf\m3cm-2_3_0_rule_help-en_US\m3cm.CMGroup.2.html" active="yes" id="Mandatory Rules">
      <text></text>
      <enforcement>
        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-2.1.html" active="yes" id="Rule-2.1">
          <text>A project shall not contain unreachable code</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
            <category>Unused code</category>
          </categories>
          <enforcement>
            <message mapped="yes" component="qac" id="0594"/>
            <message mapped="yes" component="qac" id="1460"/>
            <message mapped="yes" component="qac" id="2744"/>
            <message mapped="yes" component="qac" id="2880"/>
            <message mapped="yes" component="qac" id="2882"/>
            <message mapped="yes" component="qac" id="3219"/>
            <message mapped="yes" component="rcma" id="1503"/>
          </enforcement>
        </rule>
        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-3.1.html" active="yes" id="Rule-3.1">
          <text>The character sequences /* and // shall not be used within a comment.</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
            <category>Comments</category>
          </categories>
          <enforcement>
            <message mapped="yes" component="qac" id="3108"/>
          </enforcement>
        </rule>
        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-4.2.html" active="yes" id="Rule-4.2">
          <text>Trigraphs should not be used</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
            <category>Character sets and lexical conventions</category>
          </categories>
          <enforcement>
            <message mapped="yes" component="qac" id="3601"/>
          </enforcement>
        </rule>
        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-5.1.html" active="yes" id="Rule-5.1">
          <text>External identifiers shall be distinct</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
            <category>Identifiers</category>
          </categories>
          <enforcement>
            <message mapped="yes" component="qac" id="0777"/>
          </enforcement>
        </rule>
        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-5.2.html" active="yes" id="Rule-5.2">
          <text>Identifiers declared in the same scope and name space shall be distinct</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
            <category>Identifiers</category>
          </categories>
          <enforcement>
            <message mapped="yes" component="qac" id="0779"/>
          </enforcement>
        </rule>
        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-5.3.html" active="yes" id="Rule-5.3">
          <text>An identifier declared in an inner scope shall not hide an identifier declared in an outer scope</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
            <category>Identifiers</category>
          </categories>
          <enforcement>
            <message mapped="yes" component="qac" id="0795"/>
            <message mapped="yes" component="qac" id="2547"/>
