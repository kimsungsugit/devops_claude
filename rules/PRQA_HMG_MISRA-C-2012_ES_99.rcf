        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-8.3.html" active="yes" id="Rule-8.3">
          <text>All declarations of an object or function shall use the same names and type qualifiers</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
