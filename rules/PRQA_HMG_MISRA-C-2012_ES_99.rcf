          </enforcement>
        </rule>
        <rule help="m3cm-2_3_0_rule_help-en_US\Rule-5.4.html" active="yes" id="Rule-5.4">
          <text>Macro identifiers shall be distinct</text>
          <categories>
            <category>MISRA Mandatory Rules</category>
            <category>Mandatory</category>
            <category>Rule</category>
            <category>Rules</category>
