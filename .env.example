# =============================================================================
# DevOps Analysis Toolkit - Environment Variables
# Copy this file to .env and customize values for your environment.
# =============================================================================

# --- Project Root ---
# DEVOPS_PROJECT_ROOT=/app/my_lin_gateway

# --- Jenkins Integration ---
DEVOPS_JENKINS_BASE_URL=http://localhost:8080
DEVOPS_JENKINS_USERNAME=admin
DEVOPS_JENKINS_API_TOKEN=your-api-token-here
DEVOPS_JENKINS_HIDE_CREDENTIALS=1
DEVOPS_JENKINS_VERIFY_TLS=1
DEVOPS_JENKINS_LOG_SCAN_LIMIT=6
# DEVOPS_JENKINS_SERVER_ROOTS=C:/ProgramData/Jenkins/.jenkins

# --- LLM / AI Configuration ---
# Google API key (used by OAI_CONFIG_LIST when api_key="ENV:GOOGLE_API_KEY")
GOOGLE_API_KEY=your-google-api-key-here
# Path to OAI_CONFIG_LIST JSON file
# DEVOPS_OAI_CONFIG_PATH=/app/OAI_CONFIG_LIST
# Force Gemini-only mode (1=yes, 0=no)
LLM_GEMINI_ONLY=1
LLM_GEMINI_PREFERRED_SUBSTRING=gemini-3
LLM_READ_TIMEOUT=300
LLM_MAX_INPUT_TOKENS=1000000
GITHUB_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# --- RAG / Knowledge Base ---
# Storage backend: sqlite or pgvector
KB_STORAGE=sqlite
# PGVECTOR_DSN=postgresql://user:pass@localhost:5432/devops_kb
# PGVECTOR_URL=postgresql://user:pass@localhost:5432/devops_kb
# KB_GLOBAL_DIR=C:/Users/username/.devops_kb
# KB_SOURCES_DIR=
FORCE_PGVECTOR=0

# --- External Document Paths (comma-separated) ---
# VC_REPORTS_PATHS=
# UDS_SPEC_PATHS=
# REQ_DOCS_PATHS=
# CODEBASE_PATHS=

# --- Build & Test ---
# AUTO_INSTALL_GCOVR=1
# TEST_GEN_TIMEOUT_SEC=60

# --- Misc ---
# DEVOPS_RELAX_TOOLCHECK=1  (Windows: skip gcc/cmake/etc checks)
# OLLAMA_BASE_URL=http://localhost:11434
