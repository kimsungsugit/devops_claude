# CMake 최소 요구 버전 설정
cmake_minimum_required(VERSION 3.13)

# HOST_BUILD 모드 체크 (테스트/커버리지용 빌드)
# HOST_BUILD=1일 때는 Pico SDK 없이 호스트에서 빌드
if(DEFINED HOST_BUILD AND HOST_BUILD)
    # 호스트 빌드 모드: Pico SDK 없이 빌드
    project(lin_gateway_rp2040 C CXX ASM)
    
    # C/C++ 표준 버전 설정
    set(CMAKE_C_STANDARD 11)
    set(CMAKE_CXX_STANDARD 17)
    
    # 커버리지 설정
    # DEVOPS_COVERAGE 변수 체크 (ON, YES, TRUE, 1 등이면 참)
    if(DEVOPS_COVERAGE)
        message(STATUS "Coverage enabled: DEVOPS_COVERAGE=${DEVOPS_COVERAGE}")
        # 커버리지 컴파일러 플래그 추가
        set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -fprofile-arcs -ftest-coverage")
        set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fprofile-arcs -ftest-coverage")
        # 링커 플래그 추가
        set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -fprofile-arcs -ftest-coverage")
        # gcov 라이브러리 링크
        set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -lgcov")
    else()
        message(STATUS "Coverage disabled: DEVOPS_COVERAGE=${DEVOPS_COVERAGE} (OFF or not set)")
    endif()
    
    # AddressSanitizer 설정
    if(DEFINED SANITIZER_PROD AND SANITIZER_PROD STREQUAL "asan")
        # Windows MinGW에서는 ASan을 지원하지 않으므로 비활성화
        if(CMAKE_SYSTEM_NAME STREQUAL "Windows" OR MINGW)
            message(STATUS "AddressSanitizer disabled on Windows/MinGW (not supported)")
        else()
            message(STATUS "AddressSanitizer enabled")
            set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -fsanitize=address -fno-omit-frame-pointer")
            set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fsanitize=address -fno-omit-frame-pointer")
            set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -fsanitize=address")
        endif()
    endif()
    
    # 소스 파일로부터 실행 파일 정의 (호스트 빌드)
    add_executable(${PROJECT_NAME}
        main.c
        libs/lin_protocol.c
        libs/lin_slave.c
        libs/lin_master.c
        libs/gateway_logic.c
        libs/shared_data.c
        libs/rotary_switch.c
        libs/e2e.c
    )
    
    # 인클루드 경로에 디렉토리 추가
    target_include_directories(${PROJECT_NAME} PRIVATE 
        ${CMAKE_CURRENT_LIST_DIR}
        ${CMAKE_CURRENT_LIST_DIR}/libs
    )
    
    # 스텁 헤더 경로 추가 (tests/stubs가 있으면)
    if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/tests/stubs")
        target_include_directories(${PROJECT_NAME} PRIVATE 
            ${CMAKE_CURRENT_LIST_DIR}/tests/stubs
        )
    endif()
    
else()
    # 타겟 빌드 모드: Raspberry Pi Pico SDK 사용
    # Raspberry Pi Pico SDK 가져오기 (프로젝트 정의보다 먼저 와야 함)
    # pico_sdk_import.cmake 파일의 경로를 정확하게 지정해야 합니다.
    # 예: include(D:/pico/pico-sdk/external/pico_sdk_import.cmake)
    include(pico_sdk_import.cmake)
    
    # 프로젝트 이름 및 언어 설정
    project(lin_gateway_rp2040 C CXX ASM)
    
    # C/C++ 표준 버전 설정
    set(CMAKE_C_STANDARD 11)
    set(CMAKE_CXX_STANDARD 17)
    
    # PICO_SDK 초기화
    pico_sdk_init()
    
    # 소스 파일로부터 실행 파일 정의
    add_executable(${PROJECT_NAME}
        main.c
        libs/lin_protocol.c
        libs/lin_slave.c
        libs/lin_master.c
        libs/gateway_logic.c
        libs/shared_data.c
        libs/rotary_switch.c
        libs/e2e.c
    )
    
    # .pio 소스 파일로부터 C 헤더 파일 생성 (ws2812.pio)
    pico_generate_pio_header(${PROJECT_NAME} ${CMAKE_CURRENT_LIST_DIR}/ws2812.pio)
    
    # 실행 파일에 필요한 라이브러리 링크
    target_link_libraries(${PROJECT_NAME}
        pico_stdlib
        hardware_uart
        hardware_gpio
        hardware_irq
        hardware_timer
        hardware_pio     # WS2812 PIO에 필요
        hardware_clocks  # WS2812 주파수 계산에 필요
        hardware_adc     # ADC 사용을 위해 추가
        pico_multicore   # 듀얼코어 지원에 필요
    )
    
    # printf를 위한 USB CDC 시리얼 출력 활성화
    pico_enable_stdio_usb(${PROJECT_NAME} 1)
    pico_enable_stdio_uart(${PROJECT_NAME} 0) 
    
    # map/bin/hex/uf2 파일 등 추가 출력물 생성
    pico_add_extra_outputs(${PROJECT_NAME})
    
    # 인클루드 경로에 디렉토리 추가
    target_include_directories(${PROJECT_NAME} PRIVATE 
        ${CMAKE_CURRENT_LIST_DIR}
        ${CMAKE_CURRENT_LIST_DIR}/libs
    )
endif()
