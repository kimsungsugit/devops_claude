        #region Event 
        public UCTestCaseList()
        {
            InitializeComponent();
            m_FlexGridLib = new FlexgidLib();
            IsActualDataOnly = false;

            m_DicUserCodeResult = new Dictionary<GridPosition, TUserCode>();
